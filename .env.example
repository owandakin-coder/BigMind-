# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SERVER ONLY — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── n8n Orchestrator ─────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/courseforge-status-change
SUPABASE_WEBHOOK_SECRET=<32+ char random hex>

# ─── Cost Guardrails ──────────────────────────────────────────────────────────
MAX_COST_PER_CALL_USD=0.50

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: set to your actual domain, e.g. https://courseforge.ai
ALLOWED_ORIGIN=http://localhost:3000

# ─── Optional: Stripe (not required for MVP) ──────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
