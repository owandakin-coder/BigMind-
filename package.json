{
  "name": "courseforge-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push --linked",
    "db:types": "supabase gen types typescript --linked > src/types/database.types.ts",
    "db:seed": "supabase db reset --db-url $DATABASE_URL",
    "functions:serve": "supabase functions serve --env-file .env.local",
    "functions:deploy": "supabase functions deploy",
    "verify:rls": "node scripts/verify-rls.mjs",
    "embeddings:ingest": "node scripts/ingest-market-embeddings.mjs",
    "embeddings:ingest:file": "node scripts/ingest-market-embeddings.mjs --file",
    "test:integration": "vitest run tests/approval-flow.test.ts",
    "test:unit": "vitest run tests/state-machine.test.ts",
    "test:e2e-workflow": "vitest run tests/e2e/workflow.test.ts",
    "validate:system": "node tests/e2e/validation-report.mjs",
    "seed": "node scripts/seed-test-data.mjs",
    "seed:clean": "node scripts/seed-test-data.mjs --clean"
  },
  "dependencies": {
    "next": "15.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@supabase/supabase-js": "2.49.0",
    "@supabase/ssr": "0.6.1",
    "@tanstack/react-query": "5.62.0",
    "zod": "3.22.4",
    "recharts": "2.14.0",
    "tailwind-merge": "2.6.0",
    "clsx": "2.1.1",
    "openai": "4.73.0",
    "pg": "8.13.0"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.7.2",
    "eslint": "9.0.0",
    "eslint-config-next": "15.2.0",
    "vitest": "2.1.0",
    "@vitest/ui": "2.1.0",
    "@playwright/test": "1.49.0",
    "tailwindcss": "3.4.17",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "@types/pg": "8.11.0"
  }
}
